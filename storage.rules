rules_version = '2';

// Usta Cepte — Cloud Storage güvenlik kuralları.
//
// Model: pazaryeri görselleri (profil fotoğrafı, iş galerisi, ilan fotoğrafı,
// sertifika, sohbet fotoğrafı) KAMUYA AÇIK içeriktir — misafir de Keşfet'te
// ustaları/ilanları görür. Bu yüzden OKUMA herkese açık.
// YAZMA yalnızca oturum açmış kullanıcıya; ayrıca sunucu tarafında da tür/boyut
// sınırı (istemci image_picker ile küçültse de savunma katmanı).
//
// Yollar (bkz. FirebaseStorageRepository): profile/, work/, job/, certificate/, chat/
service firebase.storage {
  match /b/{bucket}/o {
    // Ortak: geçerli bir görsel yükleme mi? (≤6 MB).
    // SVG/HTML image/* XSS riski → yalnız yaygın raster formatlar (S-STOR-1).
    function isValidImage() {
      return request.resource != null
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches(
            'image/(jpeg|jpg|png|webp|gif|heic|heif)');
    }

    // Takip Merkezi bulut yedeği ekleri (Faz 5): track/{uid}/{kayıtId}/{dosya}.
    // KİŞİSEL veridir → yukarıdaki kamuya açık kuraldan FARKLI olarak yalnızca
    // sahibi okur/yazar (foto/dosya/ses; yalnız görsel değil). Bu yol 4
    // segmentli olduğundan aşağıdaki 3 segmentli genel kuralla ÇAKIŞMAZ
    // (Storage tek segmentli joker eşleşmesi yapar) → yanlışlıkla herkese
    // açılmaz. Boyut sınırı 25 MB (ses/dosya ekleri görsellerden büyük olabilir).
    match /track/{uid}/{recordId}/{fileName} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid
        && (request.resource == null
            || request.resource.size < 25 * 1024 * 1024);
    }

    // Platform marka varlıkları (logo vb.) — herkes okur; yalnız admin yazar.
    // Yol: platform/{uid}/{dosya} — uid = yükleyen admin (denetim izi).
    match /platform/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.auth.token.get('admin', false) == true
        && isValidImage();
    }

    // Yeni yükleme yolu: {klasör}/{uid}/{dosya} — herkes yalnızca KENDİ uid
    // klasörüne yazabilir (başkasının görselini ezme/istenmeyen klasör yok).
    match /{folder}/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && folder in ['profile', 'work', 'job', 'certificate', 'chat']
        && isValidImage();
    }

    // Eski düz yol ({klasör}/{dosya}): mevcut görseller okunmaya devam eder,
    // ancak bu yola YENİ yazım kapalıdır (sahiplik kanıtlanamaz).
    match /{folder}/{fileName} {
      allow read: if true;
      allow write: if false;
    }
  }
}
